{
  "version": 3,
  "configurePresets": [
      {
          "name": "windows-base",
          "hidden": true,
          "generator": "Ninja",
          "condition": {
              "type": "equals",
              "lhs": "${hostSystemName}",
              "rhs": "Windows"
          }
      },
      {
          "name": "x64-base",
          "hidden": true,
          "inherits": "windows-base",
          "architecture": {
              "value": "x64",
              "strategy": "external"
          }
      },
      {
          "name": "vs-x64-debug",
          "displayName": "VS x64 Debug",
          "inherits": "x64-base",
          "binaryDir": "${sourceDir}/Build/vs/x64-debug",
          "cacheVariables": {
              "CMAKE_BUILD_TYPE": "Debug"
          }
      },
      {
          "name": "vs-x64-release",
          "displayName": "VS x64 Release",
          "inherits": "vs-x64-debug",
          "binaryDir": "${sourceDir}/Build/vs/x64-release",
          "cacheVariables": {
              "CMAKE_BUILD_TYPE": "Release"
          }
      },
      {
          "name": "vscode-x64-debug",
          "displayName": "VSCode x64 Debug",
          "inherits": "x64-base",
          "binaryDir": "${sourceDir}/Build/vscode/x64-debug",
          "cacheVariables": {
              "CMAKE_BUILD_TYPE": "Debug"
          }
      },
      {
          "name": "vscode-x64-release",
          "displayName": "VSCode x64 Release",
          "inherits": "vscode-x64-debug",
          "binaryDir": "${sourceDir}/Build/vscode/x64-release",
          "cacheVariables": {
              "CMAKE_BUILD_TYPE": "Release"
          }
      }
  ]
}