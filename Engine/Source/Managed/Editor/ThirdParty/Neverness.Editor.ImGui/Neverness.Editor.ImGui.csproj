<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<AssemblyName>Neverness.Editor.ImGui</AssemblyName>
		<TargetFramework>net10.0</TargetFramework>

		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>

		<LangVersion>12</LangVersion>

		<!-- 关闭所有重型分析器 -->
		<EnableTrimAnalyzer>false</EnableTrimAnalyzer>
		<EnableSingleFileAnalyzer>false</EnableSingleFileAnalyzer>
		<EnableAotAnalyzer>false</EnableAotAnalyzer>
		<IsAotCompatible>false</IsAotCompatible>

		<!-- ThirdParty/Directory.Build.props 已覆盖 GenerateAssemblyInfo=true，此处关闭 -->
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
	</PropertyGroup>

	<!-- ========================= -->
	<!-- DEPENDENCIES -->
	<!-- ========================= -->

	<!-- ========================= -->
	<!-- PACKAGING (disabled in dev) -->
	<!-- ========================= -->
	<ItemGroup>
		<None Include="LICENSE.txt" CopyToOutputDirectory="PreserveNewest" />
		<None Include="README.md" CopyToOutputDirectory="PreserveNewest" />
	</ItemGroup>
	<ItemGroup>
	  <ProjectReference Include="..\HexaGen.Runtime\HexaGen.Runtime.csproj" />
	</ItemGroup>

</Project>
