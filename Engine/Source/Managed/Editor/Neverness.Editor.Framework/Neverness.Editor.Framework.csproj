<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>Neverness.Editor.Framework</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RollForward>LatestMinor</RollForward>
    <RootNamespace>VisionGal.Managed.Editor</RootNamespace>

    <BaseOutputPath>$(SolutionDir)Build\bin\</BaseOutputPath>
    <OutputPath>$(BaseOutputPath)$(Configuration)\</OutputPath>

    <!-- 直接写死项目名，强制生效，绕过变量解析bug -->
    <IntermediateOutputPath>$(SolutionDir)Build\Intermediate\Neverness.Editor.Framework\$(Configuration)\</IntermediateOutputPath>

    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Runtime\Neverness.Runtime.Object\Neverness.Runtime.Object.csproj" />
  </ItemGroup>
</Project>
