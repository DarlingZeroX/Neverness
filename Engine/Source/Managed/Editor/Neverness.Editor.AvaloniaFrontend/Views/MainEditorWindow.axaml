<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        xmlns:dockModels="clr-namespace:Dock.Model.Mvvm.Controls;assembly=Dock.Model.Mvvm"
        x:Class="Neverness.Editor.AvaloniaFrontend.Views.MainEditorWindow"
        Title="Neverness Editor"
        Width="1600"
        Height="900"
        MinWidth="1280"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        SystemDecorations="Full"
        Background="#FF1E1E1E">

    <DockPanel>
        <!-- 菜单栏（顶部） -->
        <Menu x:Name="MenuBar" DockPanel.Dock="Top"/>

        <!-- 工具栏（菜单下方） -->
        <StackPanel x:Name="ToolbarPanel" DockPanel.Dock="Top" Orientation="Horizontal" Background="#FF2D2D30" Height="32"/>

        <!-- 状态栏（底部） -->
        <DockPanel x:Name="StatusBar" DockPanel.Dock="Bottom" Height="24" Background="#FF007ACC"/>

        <!-- Dock 布局（中间） -->
        <dock:DockControl x:Name="DockControl" AutoCreateDataTemplates="True"/>
    </DockPanel>

</Window>
