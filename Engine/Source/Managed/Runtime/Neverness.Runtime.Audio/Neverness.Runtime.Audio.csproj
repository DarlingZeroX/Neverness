<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<AssemblyName>Neverness.Runtime.Audio</AssemblyName>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<RootNamespace>Neverness.Runtime.Audio</RootNamespace>

		<!-- ========================= -->
		<!--  关闭 pack（开发阶段） -->
		<!-- ========================= -->
		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<GenerateDocumentationFile>false</GenerateDocumentationFile>

		<!-- ========================= -->
		<!--  输出优化 -->
		<!-- ========================= -->
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
		<AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>

		<BaseOutputPath>$(SolutionDir)Build\bin\</BaseOutputPath>

		<OutputPath>$(BaseOutputPath)\$(Configuration)\</OutputPath>

		<BaseIntermediateOutputPath>$(SolutionDir)Build\obj\$(MSBuildProjectName)\</BaseIntermediateOutputPath>

		<!-- 允许并行 -->
		<BuildInParallel>true</BuildInParallel>
	</PropertyGroup>
	<!-- 零依赖：纯接口模块 -->
</Project>
