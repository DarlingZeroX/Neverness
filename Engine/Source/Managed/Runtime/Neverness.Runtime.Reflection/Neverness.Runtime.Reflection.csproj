<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>Neverness.Runtime.Reflection</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RollForward>LatestMinor</RollForward>
    <RootNamespace>Neverness.Managed.Reflection</RootNamespace>

    <BaseOutputPath>$(SolutionDir)Build\bin\</BaseOutputPath>
    <OutputPath>$(BaseOutputPath)$(Configuration)\</OutputPath>

    <!-- 直接写死项目名，强制生效，绕过变量解析bug -->
    <IntermediateOutputPath>$(SolutionDir)Build\Intermediate\Neverness.Runtime.Reflection\$(Configuration)\</IntermediateOutputPath>

    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Neverness.Runtime.Object\Neverness.Runtime.Object.csproj" />
  </ItemGroup>
</Project>
