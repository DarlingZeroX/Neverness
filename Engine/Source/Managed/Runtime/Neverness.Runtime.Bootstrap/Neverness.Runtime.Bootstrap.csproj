<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>Neverness.Runtime.Bootstrap</AssemblyName>
    <RootNamespace>Neverness.Managed.Bootstrap</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RollForward>LatestMinor</RollForward>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Neverness.Runtime.Application\Neverness.Runtime.Application.csproj" />
    <ProjectReference Include="..\Neverness.Runtime.Engine\Neverness.Runtime.Engine.csproj" />
    <ProjectReference Include="..\Neverness.Runtime.Settings\Neverness.Runtime.Settings.csproj" />
    <ProjectReference Include="..\Neverness.Runtime.RuntimeLoop\Neverness.Runtime.RuntimeLoop.csproj" />
  </ItemGroup>
</Project>
