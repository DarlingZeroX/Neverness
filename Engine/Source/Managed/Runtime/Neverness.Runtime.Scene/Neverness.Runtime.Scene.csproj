<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>Neverness.Runtime.Scene</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RollForward>LatestMinor</RollForward>
    <RootNamespace>Neverness.Runtime.Scene</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <!-- 排除测试目录 -->
    <Compile Remove="Tests\**" />
    <EmbeddedResource Remove="Tests\**" />
    <None Remove="Tests\**" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Neverness.Editor.Assets" />
    <InternalsVisibleTo Include="Neverness.Runtime.Scene.Tests" />
  </ItemGroup>
  <ItemGroup>
    <!-- Friflo ECS 核心框架 -->
    <PackageReference Include="Friflo.Engine.ECS" Version="3.6.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Neverness.Runtime.Engine\Neverness.Runtime.Engine.csproj" />
    <ProjectReference Include="..\Neverness.Runtime.RuntimeLoop\Neverness.Runtime.RuntimeLoop.csproj" />
    <ProjectReference Include="..\Neverness.Runtime.VFS\Neverness.Runtime.VFS.csproj" />
    <!-- Source Generator：组件序列化代码生成 -->
    <ProjectReference Include="..\..\Gameplay\Neverness.SourceGenerators\Neverness.SourceGenerators.csproj"
                      OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>
</Project>
