<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Common Colors (UE 风格) ============ -->
    <Color x:Key="PrimaryColor">#4A9EFF</Color>
    <Color x:Key="PrimaryLightColor">#6BB3FF</Color>
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FF9800</Color>
    <Color x:Key="ErrorColor">#F44336</Color>

    <!-- ============ Dynamic Theme Brushes ============ -->
    <ResourceDictionary.ThemeDictionaries>
        <!-- Dark Theme - UE 引擎风格 -->
        <ResourceDictionary x:Key="Dark">
            <!-- 背景色系 -->
            <SolidColorBrush x:Key="AppBackground" Color="#1A1A1A"/>
            <SolidColorBrush x:Key="AppSurface" Color="#2A2A2A"/>
            <SolidColorBrush x:Key="AppCard" Color="#333333"/>
            <SolidColorBrush x:Key="AppContentBackground" Color="#222222"/>

            <!-- 文本色系 -->
            <SolidColorBrush x:Key="AppTextPrimary" Color="#E0E0E0"/>
            <SolidColorBrush x:Key="AppTextSecondary" Color="#999999"/>
            <SolidColorBrush x:Key="AppTextDisabled" Color="#666666"/>

            <!-- 边框和分隔线 -->
            <SolidColorBrush x:Key="AppBorder" Color="#444444"/>
            <SolidColorBrush x:Key="AppSeparator" Color="#3A3A3A"/>

            <!-- 交互色系 -->
            <SolidColorBrush x:Key="AppHover" Color="#3A3A3A"/>
            <SolidColorBrush x:Key="AppPressed" Color="#444444"/>
            <SolidColorBrush x:Key="AppSelected" Color="#4A9EFF33"/>

            <!-- 输入控件 -->
            <SolidColorBrush x:Key="AppInputBackground" Color="#2A2A2A"/>
            <SolidColorBrush x:Key="AppInputBorder" Color="#555555"/>

            <!-- 按钮 -->
            <SolidColorBrush x:Key="AppButtonBackground" Color="#3A3A3A"/>
            <SolidColorBrush x:Key="AppButtonHover" Color="#444444"/>
            <SolidColorBrush x:Key="AppButtonText" Color="#E0E0E0"/>

            <!-- 导航栏 -->
            <SolidColorBrush x:Key="AppNavBackground" Color="#252525"/>

            <!-- 标题栏 -->
            <SolidColorBrush x:Key="AppTitleBar" Color="#1E1E1E"/>

            <!-- 窗口控制按钮 -->
            <SolidColorBrush x:Key="AppCloseHover" Color="#E81123"/>
        </ResourceDictionary>

        <!-- Light Theme -->
        <ResourceDictionary x:Key="Light">
            <!-- 背景色系 -->
            <SolidColorBrush x:Key="AppBackground" Color="#F5F5F5"/>
            <SolidColorBrush x:Key="AppSurface" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AppCard" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AppContentBackground" Color="#FAFAFA"/>

            <!-- 文本色系 -->
            <SolidColorBrush x:Key="AppTextPrimary" Color="#1A1A1A"/>
            <SolidColorBrush x:Key="AppTextSecondary" Color="#666666"/>
            <SolidColorBrush x:Key="AppTextDisabled" Color="#999999"/>

            <!-- 边框和分隔线 -->
            <SolidColorBrush x:Key="AppBorder" Color="#E0E0E0"/>
            <SolidColorBrush x:Key="AppSeparator" Color="#EEEEEE"/>

            <!-- 交互色系 -->
            <SolidColorBrush x:Key="AppHover" Color="#F0F0F0"/>
            <SolidColorBrush x:Key="AppPressed" Color="#E5E5E5"/>
            <SolidColorBrush x:Key="AppSelected" Color="#4A9EFF22"/>

            <!-- 输入控件 -->
            <SolidColorBrush x:Key="AppInputBackground" Color="#F5F5F5"/>
            <SolidColorBrush x:Key="AppInputBorder" Color="#CCCCCC"/>

            <!-- 按钮 -->
            <SolidColorBrush x:Key="AppButtonBackground" Color="#E8E8E8"/>
            <SolidColorBrush x:Key="AppButtonHover" Color="#DDDDDD"/>
            <SolidColorBrush x:Key="AppButtonText" Color="#1A1A1A"/>

            <!-- 导航栏 -->
            <SolidColorBrush x:Key="AppNavBackground" Color="#EEEEEE"/>

            <!-- 标题栏 -->
            <SolidColorBrush x:Key="AppTitleBar" Color="#FFFFFF"/>

            <!-- 窗口控制按钮 -->
            <SolidColorBrush x:Key="AppCloseHover" Color="#E81123"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
